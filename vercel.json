{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/js/script.js",
      "destination": "https://plausible.io/js/pa-RQwOqd9B8-_BqqjSQlXqk.js"
    },
    {
      "source": "/api/event",
      "destination": "https://plausible.io/api/event"
    },
    {
      "source": "/radar",
      "destination": "https://plumber-gitlab-ecosystem-scan.vercel.app/radar"
    },
    {
      "source": "/radar/:path*",
      "destination": "https://plumber-gitlab-ecosystem-scan.vercel.app/radar/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/docs/cli/gitlab-component",
      "destination": "/docs/cli/gitlab#gitlab-ci-component",
      "permanent": true
    },
    {
      "source": "/docs/cli/gitlab-component/",
      "destination": "/docs/cli/gitlab#gitlab-ci-component",
      "permanent": true
    },
    {
      "source": "/admin",
      "destination": "/keystatic",
      "permanent": true
    },
    {
      "source": "/categories",
      "destination": "/blog",
      "permanent": true
    },
    {
      "source": "/categories/:path*",
      "destination": "/blog",
      "permanent": true
    },
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "permanent": true
    }
  ]
}
