---
/**
 * Issue documentation page.
 * Displays full details for a Plumber issue: description, impact,
 * remediation with before/after configuration examples.
 *
 * Each issue carries per-provider content (gitlab / github). When
 * both providers exist, a tab switcher at the top swaps the whole
 * page body between the two. The active provider is persisted in
 * localStorage and reflected as a `?p=` query parameter so links
 * across the issues / controls pages preserve the choice.
 *
 * URLs:
 *   /docs/use-plumber/issues/ISSUE-101  (Platform tab)
 *   /docs/cli/issues/ISSUE-101         (Open Source CLI tab)
 */
import { Code as ExpressiveCode } from "astro-expressive-code/components";
import { Icon } from "astro-icon/components";

import {
  Breadcrumb,
  BreadcrumbItem,
  BreadcrumbLink,
  BreadcrumbList,
  BreadcrumbPage,
  BreadcrumbSeparator,
} from "@/components/starwind/breadcrumb";
import { issueCodeRedirects } from "@/data/issueCodeRedirects";
import {
  type IssueDoc,
  type IssueProviderContent,
  issueDisplayTitle,
  issues,
  isVisibleProviderContent,
  type Provider,
} from "@/data/issues";
import {
  fixDurationBadge,
  severityBadge,
} from "@/docs/components/mdx-components/IssuesList.astro";
import ProductScopeBadge from "@/docs/components/mdx-components/ProductScopeBadge.astro";
import ProviderTabs from "@/docs/components/mdx-components/ProviderTabs.astro";
import {
  CLI_DOCS_PREFIX,
  CLI_DOCS_TAB_ID,
  getSharedDocsBasePath,
  PLATFORM_DOCS_PREFIX,
} from "@/docs/js/docsUtils";
import DocsLayoutStandalone from "@/docs/layouts/DocsLayoutStandalone.astro";

export function getStaticPaths() {
  const sections = [PLATFORM_DOCS_PREFIX, CLI_DOCS_PREFIX] as const;
  const canonical = sections.flatMap((section) =>
    Object.entries(issues).map(([code, doc]) => ({
      params: { section, code },
      props: { ...doc, redirectTo: null as string | null },
    })),
  );
  const legacy = sections.flatMap((section) =>
    Object.entries(issueCodeRedirects).map(([oldCode, newCode]) => ({
      params: { section, code: oldCode },
      props: { redirectTo: newCode },
    })),
  );
  return [...canonical, ...legacy];
}

type Props = IssueDoc & { redirectTo?: string | null };

const section = Astro.params.section as string;
const isSharedSection =
  section === PLATFORM_DOCS_PREFIX || section === CLI_DOCS_PREFIX;
if (!isSharedSection) {
  return Astro.redirect("/404");
}

const tabId = section === CLI_DOCS_PREFIX ? CLI_DOCS_TAB_ID : "main";
const docsBase = getSharedDocsBasePath(tabId);

const props = Astro.props as Props;
const redirectTo = props.redirectTo ?? issueCodeRedirects[Astro.params.code ?? ""];
if (redirectTo) {
  const search = Astro.url.search;
  return Astro.redirect(`${docsBase}/issues/${redirectTo}${search}`);
}

const { code, gitlab, github } = props;

type PanelDescriptor = {
  id: Provider;
  label: string;
  icon: string;
  content: IssueProviderContent;
};

const panels: PanelDescriptor[] = [];
if (gitlab && isVisibleProviderContent(gitlab)) {
  panels.push({ id: "gitlab", label: "GitLab", icon: "tabler/brand-gitlab", content: gitlab });
}
if (github && isVisibleProviderContent(github)) {
  panels.push({ id: "github", label: "GitHub", icon: "tabler/brand-github", content: github });
}

if (panels.length === 0) {
  return Astro.redirect(`${docsBase}/issues`);
}

const requestedProvider = Astro.url.searchParams.get("p");
if (
  (requestedProvider === "gitlab" || requestedProvider === "github") &&
  !panels.some((p) => p.id === requestedProvider)
) {
  const url = new URL(Astro.url);
  url.searchParams.set("p", panels[0].id);
  return Astro.redirect(url.pathname + url.search);
}

const defaultProvider: Provider = panels[0].id;
const defaultContent = panels[0].content;
const issueDoc: IssueDoc = { code, gitlab, github };
const defaultPageTitle = issueDisplayTitle(issueDoc, defaultProvider) ?? defaultContent.title;

const severityColors: Record<string, { bg: string; text: string; ring: string; label: string }> = {
  critical: {
    bg: "bg-red-100 dark:bg-red-900/40",
    text: "text-red-700 dark:text-red-400",
    ring: "ring-red-300 dark:ring-red-700/50",
    label: "Critical",
  },
  high: {
    bg: "bg-orange-100 dark:bg-orange-900/40",
    text: "text-orange-700 dark:text-orange-400",
    ring: "ring-orange-300 dark:ring-orange-700/50",
    label: "High",
  },
  medium: {
    bg: "bg-yellow-100 dark:bg-yellow-900/40",
    text: "text-yellow-700 dark:text-yellow-400",
    ring: "ring-yellow-300 dark:ring-yellow-700/50",
    label: "Medium",
  },
  low: {
    bg: "bg-blue-100 dark:bg-blue-900/40",
    text: "text-blue-700 dark:text-blue-400",
    ring: "ring-blue-300 dark:ring-blue-700/50",
    label: "Low",
  },
};

const fixDurationStyles: Record<
  string,
  { bg: string; text: string; ring: string; label: string }
> = {
  immediate: {
    bg: "bg-emerald-100 dark:bg-emerald-900/40",
    text: "text-emerald-700 dark:text-emerald-300",
    ring: "ring-emerald-300 dark:ring-emerald-700/60",
    label: "Immediate",
  },
  "very quick": {
    bg: "bg-emerald-100 dark:bg-emerald-900/40",
    text: "text-emerald-700 dark:text-emerald-300",
    ring: "ring-emerald-300 dark:ring-emerald-700/60",
    label: "Very quick",
  },
  quick: {
    bg: "bg-primary/10",
    text: "text-primary",
    ring: "ring-primary/40",
    label: "Quick",
  },
  medium: {
    bg: "bg-yellow-100 dark:bg-yellow-900/40",
    text: "text-yellow-700 dark:text-yellow-300",
    ring: "ring-yellow-300 dark:ring-yellow-700/60",
    label: "Medium",
  },
  long: {
    bg: "bg-orange-100 dark:bg-orange-900/40",
    text: "text-orange-700 dark:text-orange-300",
    ring: "ring-orange-300 dark:ring-orange-700/60",
    label: "Long",
  },
  extended: {
    bg: "bg-red-100 dark:bg-red-900/40",
    text: "text-red-700 dark:text-red-300",
    ring: "ring-red-300 dark:ring-red-700/60",
    label: "Extended",
  },
};

const fixFallback = {
  bg: "bg-muted",
  text: "text-muted-foreground",
  ring: "ring-border",
  label: "Unknown",
};

// Prev/next is scoped per provider — navigating within a provider should
// only walk through codes that actually have that provider's content.
const codesByProvider: Record<Provider, string[]> = {
  gitlab: Object.keys(issues).filter(
    (c) => issues[c].gitlab != null && isVisibleProviderContent(issues[c].gitlab!),
  ),
  github: Object.keys(issues).filter(
    (c) => issues[c].github != null && isVisibleProviderContent(issues[c].github!),
  ),
};

function prevNextFor(provider: Provider): { prev: string | null; next: string | null } {
  const list = codesByProvider[provider];
  const idx = list.indexOf(code);
  return {
    prev: idx > 0 ? list[idx - 1] : null,
    next: idx >= 0 && idx < list.length - 1 ? list[idx + 1] : null,
  };
}

/** Convert markdown-style `inline code` to HTML <code> and escape the rest for safe set:html */
function inlineCodeToHtml(text: string): string {
  const escape = (s: string) =>
    s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  return text
    .split(/(`[^`]+`)/g)
    .map((part) => {
      if (part.startsWith("`") && part.endsWith("`")) {
        return "<code>" + escape(part.slice(1, -1)) + "</code>";
      }
      return escape(part);
    })
    .join("");
}

// Page TOC reflects the default provider's section IDs. The inline script
// at the bottom rewrites these hrefs on tab change so the right-sidebar
// TOC always targets the visible panel.
const showConfig = defaultContent.productScope !== "platform";
const pageHeadings: { depth: number; slug: string; text: string }[] = [
  { depth: 2, slug: `what-is-this-${defaultProvider}`, text: "What is this?" },
  { depth: 2, slug: `impact-${defaultProvider}`, text: "Impact" },
  { depth: 2, slug: `how-to-fix-${defaultProvider}`, text: "How to fix" },
  ...(defaultContent.tips.length > 0
    ? [{ depth: 2, slug: `tips-${defaultProvider}`, text: "Tips" }]
    : []),
  ...(showConfig
    ? [{ depth: 2, slug: `configuration-${defaultProvider}`, text: "Configuration" }]
    : []),
  ...(defaultContent.relatedCodes.length > 0
    ? [{ depth: 2, slug: `related-issues-${defaultProvider}`, text: "Related issues" }]
    : []),
];

function configKeyExample(provider: Provider, configKey: string): string {
  if (provider === "github") {
    return `github:\n  controls:\n    ${configKey}:\n      enabled: true`;
  }
  return `gitlab:\n  controls:\n    ${configKey}:\n      enabled: true`;
}
---

<DocsLayoutStandalone
  title={`${code} — ${defaultPageTitle} | Plumber Issues`}
  description={defaultContent.description}
  sectionId={tabId}
  headings={pageHeadings}
>
  <!-- Breadcrumb (shared across providers) -->
  <Breadcrumb class="mb-4 text-xs md:text-sm">
    <BreadcrumbList >
      <BreadcrumbItem class="pl-0!">
        <BreadcrumbLink href={`${docsBase}/controls`} class={"mt-2"}>Controls</BreadcrumbLink>
      </BreadcrumbItem>
      <BreadcrumbSeparator />
      <BreadcrumbItem>
        <BreadcrumbLink href={`${docsBase}/issues`}>Issues</BreadcrumbLink>
      </BreadcrumbItem>
      <BreadcrumbSeparator />
      <BreadcrumbItem>
        <BreadcrumbPage class="rounded-md bg-muted px-2 py-0.5 text-foreground">
          {code}
        </BreadcrumbPage>
      </BreadcrumbItem>
    </BreadcrumbList>
  </Breadcrumb>

  <!-- Provider tabs: only rendered when this issue exists on both providers. -->
  {
    panels.length > 1 && <ProviderTabs defaultProvider={defaultProvider} class="mb-8" />
  }

  <!-- One panel per provider. Inactive panel is hidden via class. -->
  {
    panels.map((p) => {
      const c = p.content;
      const sev = severityColors[c.severity];
      const fix = fixDurationStyles[c.fixDuration] ?? fixFallback;
      const resolvedScope = c.productScope === "cli" ? "cli" : c.productScope === "platform" ? "platform" : "all";
      const pn = prevNextFor(p.id);
      const panelShowConfig = c.productScope !== "platform";
      return (
        <div
          data-provider-panel={p.id}
          role="tabpanel"
          class:list={["provider-panel", p.id === defaultProvider ? "" : "hidden"]}
        >
          <header class="mb-10">
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <span
                class="inline-flex items-center rounded-md bg-emerald-100 dark:bg-emerald-900/40 px-3 py-1 text-sm font-mono font-bold text-emerald-700 dark:text-emerald-400 ring-1 ring-emerald-300 dark:ring-emerald-700/50"
                title="Unique identifier for this issue"
              >
                {code}
              </span>
              <span
                class={`inline-flex items-center leading-none gap-1 rounded-md h-[28px] px-2.5 py-1 text-sm font-medium ring-1 ring-inset ${sev.bg} ${sev.text} ${sev.ring}`}
                title="How severe the impact is if this issue is not fixed"
              >
                <Icon name="tabler/alert-triangle" color="currentColor" size="16px" />
                {sev.label}
              </span>
              <span
                class={`inline-flex items-center leading-none gap-1 rounded-md h-[28px] px-2.5 py-1 text-sm font-medium ring-1 ring-inset ${fix.bg} ${fix.text} ${fix.ring}`}
                title="Approximate time needed to fix this issue"
              >
                <Icon name="tabler/clock" color="currentColor" size="16px" />
                {fix.label}
              </span>
              <ProductScopeBadge scope={resolvedScope} size="header" />
              {c.status === "roadmap" && (
                <span
                  class="inline-flex items-center gap-1 rounded-md h-[28px] px-2.5 py-1 text-sm font-medium ring-1 ring-inset bg-amber-100 text-amber-800 ring-amber-300 dark:bg-amber-900/40 dark:text-amber-200 dark:ring-amber-700/50"
                  title="This control's Rego policy exists but findings are held back by the engine's bench gate. It is not active in the current release."
                >
                  ⏳ Roadmap
                </span>
              )}
              <span
                class="inline-flex items-center rounded-md bg-muted px-2.5 h-[28px] text-sm text-muted-foreground ring-1 ring-border"
                title="Category of the control that raised this issue"
              >
                {c.category}
              </span>
            </div>
            <h1 class="docs-h1 docs-text-gradient mb-2">
              {issueDisplayTitle(issueDoc, p.id) ?? c.title}
            </h1>
            <p class="mt-2 text-sm text-muted-foreground">
              Control: <span class="text-foreground">{c.controlName}</span>
              · Config key: <code class="text-xs bg-muted px-1.5 py-0.5 rounded text-foreground"
                >{c.controlConfigKey}</code
              >
            </p>
          </header>

          <section id={`what-is-this-${p.id}`} class="mb-8 scroll-mt-[calc(var(--nav-height)+1rem)]">
            <h2 class="docs-h2 text-xl font-semibold text-foreground mb-3 flex items-center gap-2">
              <span>📋</span> What is this?
            </h2>
            <p class="text-foreground/80 leading-relaxed" set:html={inlineCodeToHtml(c.description)} />
          </section>

          <section id={`impact-${p.id}`} class="mb-8 scroll-mt-[calc(var(--nav-height)+1rem)]">
            <h2 class="docs-h2 text-xl font-semibold text-foreground mb-3 flex items-center gap-2">
              <span>⚠️</span> Impact
            </h2>
            <div
              class={`rounded-lg border p-4 ${
                c.severity === "critical"
                  ? "border-red-300 dark:border-red-800/50 bg-red-50 dark:bg-red-950/20"
                  : "border-yellow-300 dark:border-yellow-800/50 bg-yellow-50 dark:bg-yellow-950/20"
              }`}
            >
              <p class="text-foreground/80 leading-relaxed" set:html={inlineCodeToHtml(c.impact)} />
            </div>
          </section>

          <section id={`how-to-fix-${p.id}`} class="mb-8 scroll-mt-[calc(var(--nav-height)+1rem)]">
            <h2 class="docs-h2 text-xl font-semibold text-foreground mb-3 flex items-center gap-2">
              <span>🔧</span> How to fix
            </h2>
            <p class="text-foreground/80 leading-relaxed mb-6" set:html={inlineCodeToHtml(c.remediation)} />

            <div class="mb-6">
              <div class="inline-block ">
                <span
                  class="shrink-0 mr-1 inline-block items-center rounded px-2 py-0.5 text-xs font-medium bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 ring-1 ring-red-300 dark:ring-red-800/50"
                  >✗ Before</span
                >
                <span class="text-sm text-muted-foreground">{c.badExampleCaption}</span>
              </div>
              <ExpressiveCode
                code={c.badExample}
                lang="yaml"
                class="overflow-x-auto rounded-lg text-sm leading-relaxed"
              />
            </div>

            <div class="mb-6">
              <div class="inline-block">
                <span
                  class="shrink-0 mr-1 inline-block items-center rounded px-2 py-0.5 text-xs font-medium bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 ring-1 ring-emerald-300 dark:ring-emerald-800/50"
                  >✓ After</span
                >
                <span class="text-sm text-muted-foreground">{c.goodExampleCaption}</span>
              </div>
              <ExpressiveCode
                code={c.goodExample}
                lang="yaml"
                class="overflow-x-auto rounded-lg text-sm leading-relaxed"
              />
            </div>
          </section>

          {c.tips.length > 0 && (
            <section id={`tips-${p.id}`} class="mb-8 scroll-mt-[calc(var(--nav-height)+1rem)]">
              <h2 class="docs-h2 text-xl font-semibold text-foreground mb-3 flex items-center gap-2">
                <span>💡</span> Tips
              </h2>
              <ul class="space-y-2 list-none pl-0">
                {c.tips.map((tip) => (
                  <li class="flex items-start gap-2 text-foreground/80">
                    <span class="mt-[10px] h-1.5 w-1.5 flex-shrink-0 rounded-full bg-emerald-500" />
                    <span class="flex-1 min-w-0" set:html={inlineCodeToHtml(tip)} />
                  </li>
                ))}
              </ul>
            </section>
          )}

          {panelShowConfig && (
            <section id={`configuration-${p.id}`} class="mb-8 scroll-mt-[calc(var(--nav-height)+1rem)]">
              <h2 class="docs-h2 text-xl font-semibold text-foreground mb-3 flex items-center gap-2">
                <span>⚙️</span> Configuration
              </h2>
              <p class="text-foreground/80 mb-3">
                This control is configured in{" "}
                <code class="text-xs bg-muted px-1.5 py-0.5 rounded text-foreground">.plumber.yaml</code>{" "}
                under the {p.id === "github" ? "github" : "gitlab"} section:
              </p>
              <pre
                class="overflow-x-auto rounded-lg bg-zinc-900 p-4 text-sm ring-1 ring-zinc-800"
                ><code class="text-zinc-300">{configKeyExample(p.id, c.controlConfigKey)}</code></pre>
              <p class="mt-3 text-sm text-muted-foreground">
                See the <a href="/docs/cli" class="underline">CLI documentation</a> for the full configuration
                reference.
                {c.productScope !== "cli" && (
                  <>
                    {" "}
                    On Plumber Platform, the same key is used in your policy configuration.
                  </>
                )}
              </p>
            </section>
          )}

          {c.relatedCodes.length > 0 && (
            <section id={`related-issues-${p.id}`} class="mb-10 scroll-mt-[calc(var(--nav-height)+1rem)]">
              <h2 class="docs-h2 text-xl font-semibold text-foreground mb-3 flex items-center gap-2">
                <span>🔗</span> Related issues
              </h2>
              <div class="flex flex-col gap-2">
                {c.relatedCodes.map((rc) => {
                  const related = issues[rc];
                  const relProvider: Provider | null =
                    related?.[p.id] && isVisibleProviderContent(related[p.id]!)
                      ? p.id
                      : related?.gitlab && isVisibleProviderContent(related.gitlab)
                        ? "gitlab"
                        : related?.github && isVisibleProviderContent(related.github)
                          ? "github"
                          : null;
                  const relContent = relProvider ? related?.[relProvider] : undefined;
                  if (!related || !relProvider || !relContent) return null;
                  const relSev = relContent.severity;
                  const relFix = relContent.fixDuration;
                  return (
                    <a
                      href={`${docsBase}/issues/${rc}?p=${relProvider}`}
                      class="inline-flex items-center gap-2 rounded-lg bg-muted px-3 text-sm ring-1 ring-border hover:ring-emerald-500/50 hover:bg-muted/80 transition-all h-10"
                    >
                      <span class="font-mono font-bold text-emerald-600 dark:text-emerald-400">{rc}</span>
                      <span class="text-muted-foreground">
                        {issueDisplayTitle(related, relProvider) ?? relContent.title}
                      </span>
                      <div class="flex items-center gap-1.5 shrink-0 ml-auto">
                        <span
                          class={`inline-flex items-center leading-none gap-1 rounded px-2 text-[10px] h-[26px] md:text-xs font-medium ring-1 ring-inset ${severityBadge[relSev]}`}
                          title="How severe the impact is if this issue is not fixed"
                        >
                          <Icon size="15px" name="tabler/alert-triangle" color="currentColor" class="h-3 w-3" />
                          {relSev.charAt(0).toUpperCase() + relSev.slice(1)}
                        </span>
                        <span
                          class={`inline-flex items-center leading-none gap-1 rounded px-2 text-[10px] h-[26px] md:text-xs font-medium ring-1 ring-inset ${
                            fixDurationBadge[relFix] ?? "bg-muted text-muted-foreground ring-border"
                          }`}
                          title="Approximate time needed to fix this issue"
                        >
                          <Icon size="15px" name="tabler/clock" color="currentColor" class="h-3 w-3" />
                          {(relFix.charAt(0).toUpperCase() + relFix.slice(1)).replace("quick", "Quick")}
                        </span>
                      </div>
                    </a>
                  );
                })}
              </div>
            </section>
          )}

          <nav
            class="flex items-center justify-between border-t border-border pt-6"
            aria-label="Issues navigation"
          >
            {pn.prev ? (
              <a
                href={`${docsBase}/issues/${pn.prev}?p=${p.id}`}
                class="flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors"
              >
                <span>←</span>
                <span class="font-mono">{pn.prev}</span>
              </a>
            ) : (
              <span />
            )}
            <a
              href={`${docsBase}/controls?p=${p.id}`}
              class="text-sm text-primary hover:text-primary/80 transition-colors"
            >
              All Controls →
            </a>
            {pn.next ? (
              <a
                href={`${docsBase}/issues/${pn.next}?p=${p.id}`}
                class="flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors"
              >
                <span class="font-mono">{pn.next}</span>
                <span>→</span>
              </a>
            ) : (
              <span />
            )}
          </nav>
        </div>
      );
    })
  }
</DocsLayoutStandalone>

<script is:inline define:vars={{ defaultProvider }}>
  (function () {
    const STORAGE_KEY = "plumber:docs:provider";
    const TOC_SLUGS = [
      "what-is-this",
      "impact",
      "how-to-fix",
      "tips",
      "configuration",
      "related-issues",
    ];

    function panelExists(p) {
      return !!document.querySelector(`[data-provider-panel="${p}"]`);
    }

    function setProvider(p) {
      if (!panelExists(p)) return;
      document.querySelectorAll("[data-provider-panel]").forEach((panel) => {
        const active = panel.getAttribute("data-provider-panel") === p;
        panel.classList.toggle("hidden", !active);
      });
      document.querySelectorAll("[data-provider-tab]").forEach((tab) => {
        const active = tab.getAttribute("data-provider-tab") === p;
        tab.setAttribute("aria-selected", active ? "true" : "false");
      });
      // Rewrite right-sidebar TOC hrefs (`#what-is-this-gitlab` → `#what-is-this-github`).
      document.querySelectorAll('a[href^="#"]').forEach((a) => {
        const href = a.getAttribute("href") || "";
        const m = href.match(/^#([a-z-]+)-(gitlab|github)$/);
        if (m && TOC_SLUGS.includes(m[1])) {
          a.setAttribute("href", `#${m[1]}-${p}`);
        }
      });
      try {
        localStorage.setItem(STORAGE_KEY, p);
      } catch {
        /* localStorage unavailable (private mode, etc.); silently ignore. */
      }
      const url = new URL(window.location.href);
      url.searchParams.set("p", p);
      window.history.replaceState({}, "", url.toString());
    }

    function initialProvider() {
      const params = new URLSearchParams(window.location.search);
      const fromUrl = params.get("p");
      if ((fromUrl === "gitlab" || fromUrl === "github") && panelExists(fromUrl)) {
        return fromUrl;
      }
      let fromStorage = null;
      try {
        fromStorage = localStorage.getItem(STORAGE_KEY);
      } catch {
        /* localStorage unavailable (private mode, etc.); silently ignore. */
      }
      if ((fromStorage === "gitlab" || fromStorage === "github") && panelExists(fromStorage)) {
        return fromStorage;
      }
      return defaultProvider;
    }

    setProvider(initialProvider());

    document.querySelectorAll("[data-provider-tab]").forEach((tab) => {
      tab.addEventListener("click", () => {
        const p = tab.getAttribute("data-provider-tab");
        if (p === "gitlab" || p === "github") setProvider(p);
      });
    });
  })();
</script>
