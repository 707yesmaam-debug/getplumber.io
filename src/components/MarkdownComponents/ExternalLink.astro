---
/**
 * * This component is used to add target="_blank" and rel="noopener noreferrer" to external links
 * * and to links to /discord (which redirect to Discord, so open in new tab)
 * Used in blog posts so you don't have to worry about that when writing markdown / mdx
 */
const { href }: Record<string, any> = Astro.props;

const domain = import.meta.env.SITE; // pulls from astro.config.mjs
let attr: { target?: string; rel?: string } = {};

const isExternal = !href.includes(domain) && !href.startsWith("/") && !href.startsWith("#");
const isDiscordLink = href === "/discord" || href.endsWith("/discord");

if (isExternal || isDiscordLink) {
  attr["target"] = "_blank";
  attr["rel"] = "noopener noreferrer";
}

// Normalize internal links to remove trailing slash (except root)
let normalizedHref = href;
if (!isExternal && href.startsWith("/") && href !== "/" && href.endsWith("/")) {
  normalizedHref = href.slice(0, -1);
}
---

<a href={normalizedHref} {...attr}><slot /></a>
