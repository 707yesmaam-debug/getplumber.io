---
/**
 * * Plumber Radar showcase section.
 * Two-column layout: text + CTA on the left, custom dashboard illustration on the right.
 * Highlights the public live compliance scan at /radar.
 *
 * The illustration is pure HTML/CSS/SVG (no images) and matches the radar dashboard
 * visual language: window chrome, animated radar sweep with blips, and a list of
 * anonymized project rows with Nutri-style A-E grade badges + compliance bars.
 */
 import Button from "@components/Button/Button.astro";
import { Icon } from "astro-icon/components";

interface RadarRow {
  letter: "A" | "B" | "C" | "D" | "E";
  compliance: number; // 0-100
  segments: number[]; // bar widths used to anonymize the project path visually
}

const radarRows: RadarRow[] = [
  { letter: "A", compliance: 96, segments: [42, 78] },
  { letter: "B", compliance: 84, segments: [56, 62] },
  { letter: "C", compliance: 71, segments: [38, 88] },
  { letter: "D", compliance: 53, segments: [64, 50] },
  { letter: "E", compliance: 32, segments: [48, 70] },
];
---

<section id="plumber-radar" class="relative overflow-hidden ">
  <!-- ambient glows -->
  <div
    class="bg-primary-500/30 dark:bg-primary-500/20 pointer-events-none absolute -top-1/4 right-0 -z-10 aspect-square w-[60%] max-w-3xl translate-x-1/3 rounded-full blur-[120px]"
    aria-hidden="true"
  >
  </div>
  <div
    class="bg-primary-400/20 dark:bg-primary-500/10 pointer-events-none absolute -bottom-1/3 left-0 -z-10 aspect-square w-[55%] max-w-2xl -translate-x-1/3 rounded-full blur-[110px]"
    aria-hidden="true"
  >
  </div>

  <div class="site-container py-24 md:py-32">
    <div
      class="grid grid-cols-1 items-start gap-12 lg:grid-cols-12 lg:gap-14 xl:gap-20"
      data-mos-anchor="#plumber-radar"
    >
      <!-- ── Text column ───────────────────────────────────────── -->
      <div class="flex flex-col gap-6 lg:col-span-5">
        <p
          class="colored-title inline w-fit"
          data-mos="fade-up"
          data-mos-anchor="#plumber-radar"
        >
          Plumber Radar
        </p>

        <h2
          class="h2"
          data-mos="fade-up"
          data-mos-delay="0.1"
          data-mos-anchor="#plumber-radar"
        >
          See what's actually shipping in <span class="text-primary-500"
            >open source CI/CD</span
          >
        </h2>

        <p
          class="description"
          data-mos="fade-up"
          data-mos-delay="0.2"
          data-mos-anchor="#plumber-radar"
        >
          We point the open-source Plumber CLI at hundreds of popular public GitLab projects,
          aggregate the results, and publish them live.
        </p>

        <!-- inline stats -->
        <ul
          class="grid grid-cols-3 gap-3 sm:gap-4"
          data-mos="fade-up"
          data-mos-delay="0.3"
          data-mos-anchor="#plumber-radar"
        >
          <li
            class="border-base-300 dark:border-base-600/60 dark:bg-base-900/40 rounded-xl border bg-white/40 px-3 py-3 text-center"
          >
            <span class="text-primary-500 dark:text-primary-400 block text-xl font-semibold tracking-tight md:text-2xl">
              200+
            </span>
            <span
              class="text-base-500 dark:text-base-400 mt-0.5 block text-[0.65rem] leading-tight font-medium tracking-wide uppercase"
            >
              Projects scanned
            </span>
          </li>
          <li
            class="border-base-300 dark:border-base-600/60 dark:bg-base-900/40 rounded-xl border bg-white/40 px-3 py-3 text-center"
          >
            <span class="text-primary-500 dark:text-primary-400 block text-xl font-semibold tracking-tight md:text-2xl">
              13
            </span>
            <span
              class="text-base-500 dark:text-base-400 mt-0.5 block text-[0.65rem] leading-tight font-medium tracking-wide uppercase"
            >
              Compliance controls
            </span>
          </li>
          <li
            class="border-base-300 dark:border-base-600/60 dark:bg-base-900/40 rounded-xl border bg-white/40 px-3 py-3 text-center"
          >
            <span class="text-primary-500 dark:text-primary-400 block text-xl font-semibold tracking-tight md:text-2xl">
              A-E
            </span>
            <span
              class="text-base-500 dark:text-base-400 mt-0.5 block text-[0.65rem] leading-tight font-medium tracking-wide uppercase"
            >
              Nutri-style grades
            </span>
          </li>
        </ul>

        <!-- CTA -->
        <div
          class="mt-2 flex flex-wrap items-center gap-4"
          data-mos="fade-up"
          data-mos-delay="0.4"
          data-mos-anchor="#plumber-radar"
        >
          <Button variant="primary" href="/radar" arrow="right">
            Open Plumber Radar
          </Button>
          <a
            href="/radar"
            class="text-base-600 dark:text-base-300 hover:text-primary-600 dark:hover:text-primary-400 inline-flex items-center gap-1.5 text-sm font-medium transition-colors"
          >
            <Icon name="tabler/search" class="h-4 w-4" aria-hidden="true" />
            Scan a public project
          </a>
        </div>
      </div>

      <!-- ── Illustration column ──────────────────────────────── -->
      <div
        class="lg:col-span-7"
        data-mos="fade-up"
        data-mos-delay="0.3"
        data-mos-anchor="#plumber-radar"
      >
        <div class="pr-window">
          <!-- title bar -->
          <div class="pr-bar">
            <span class="pr-dots" aria-hidden="true"
              ><span></span><span></span><span></span></span
            >
            <span class="pr-title">getplumber.io/radar</span>
            <span class="pr-live" aria-hidden="true">
              <span class="pr-live-dot"></span>
              live
            </span>
          </div>

          <div class="pr-content">
            <!-- top row: radar + KPI stack -->
            <div class="pr-top">
              <!-- radar -->
              <div class="pr-radar-panel">
                <div class="pr-panel-head">
                  <span class="pr-panel-title">Live Plumber Radar</span>
                  <span class="pr-panel-meta">gitlab.com</span>
                </div>
                <div class="pr-radar-wrap">
                  <svg
                    class="pr-radar-svg"
                    viewBox="0 0 200 200"
                    aria-hidden="true"
                  >
                    <defs>
                      <radialGradient id="pr-radar-bg" cx="50%" cy="50%" r="50%">
                        <stop offset="0%" stop-color="rgba(34,197,94,0.18)" />
                        <stop offset="65%" stop-color="rgba(15,23,42,0.0)" />
                      </radialGradient>
                      <linearGradient
                        id="pr-sweep-grad"
                        x1="0"
                        y1="0"
                        x2="1"
                        y2="0"
                      >
                        <stop offset="0%" stop-color="rgba(34,197,94,0.55)" />
                        <stop offset="100%" stop-color="rgba(34,197,94,0)" />
                      </linearGradient>
                    </defs>

                    <!-- background disc -->
                    <circle cx="100" cy="100" r="92" fill="url(#pr-radar-bg)" />

                    <!-- concentric rings -->
                    <circle cx="100" cy="100" r="30" class="pr-ring" />
                    <circle cx="100" cy="100" r="55" class="pr-ring" />
                    <circle cx="100" cy="100" r="80" class="pr-ring" />
                    <circle cx="100" cy="100" r="92" class="pr-ring pr-ring-edge" />

                    <!-- crosshairs -->
                    <line x1="8" y1="100" x2="192" y2="100" class="pr-cross" />
                    <line x1="100" y1="8" x2="100" y2="192" class="pr-cross" />

                    <!-- sweep wedge (rotates) -->
                    <g class="pr-sweep">
                      <path
                        d="M 100 100 L 192 100 A 92 92 0 0 0 146 20 Z"
                        fill="url(#pr-sweep-grad)"
                      />
                    </g>

                    <!-- blips: each lights up under the sweep via animation-delay -->
                    <g class="pr-blips">
                      <circle cx="138" cy="62" r="3" class="pr-blip pr-blip-a" />
                      <circle cx="74" cy="48" r="3" class="pr-blip pr-blip-b" />
                      <circle cx="44" cy="118" r="3" class="pr-blip pr-blip-c" />
                      <circle cx="92" cy="146" r="3" class="pr-blip pr-blip-d" />
                      <circle cx="156" cy="132" r="3" class="pr-blip pr-blip-e" />
                      <circle cx="118" cy="92" r="3" class="pr-blip pr-blip-f" />
                    </g>

                    <!-- center pin -->
                    <circle cx="100" cy="100" r="3.5" class="pr-center" />
                    <circle cx="100" cy="100" r="6" class="pr-center-ring" />
                  </svg>
                </div>
              </div>

              <!-- KPI stack -->
              <div class="pr-kpi-col">
                <div class="pr-kpi-card">
                  <span class="pr-kpi-label">Avg score</span>
                  <span class="pr-kpi-value pr-c-green">B</span>
                  <span class="pr-kpi-sub">79.1 / 100</span>
                </div>
                <div class="pr-kpi-card">
                  <span class="pr-kpi-label">Findings</span>
                  <span class="pr-kpi-value pr-c-amber">4,356</span>
                  <span class="pr-kpi-sub">
                    <span class="pr-kpi-sev pr-sev-high">715 high+</span>
                  </span>
                </div>
              </div>
            </div>

            <!-- bottom: scan results list -->
            <div class="pr-results-panel">
              <div class="pr-panel-head">
                <span class="pr-panel-title">Recent scans</span>
                <span class="pr-panel-meta">sorted by score</span>
              </div>
              <ul class="pr-results-list">
                {
                  radarRows.map((row) => (
                    <li class="pr-result-row">
                      <span
                        class:list={[
                          "pr-grade",
                          `pr-grade-${row.letter.toLowerCase()}`,
                        ]}
                        aria-hidden="true"
                      >
                        {row.letter}
                      </span>
                      <span class="pr-path" aria-hidden="true">
                        <span
                          class="pr-path-seg"
                          style={`width: ${row.segments[0]}px`}
                        />
                        <span class="pr-path-slash">/</span>
                        <span
                          class="pr-path-seg"
                          style={`width: ${row.segments[1]}px`}
                        />
                      </span>
                      <span class="pr-bar-track">
                        <span
                          class:list={[
                            "pr-bar-fill",
                            `pr-bar-${row.letter.toLowerCase()}`,
                          ]}
                          style={`width: ${row.compliance}%`}
                        />
                      </span>
                      <span class="pr-score-num">{row.compliance}%</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── window chrome ──────────────────────────────────────────── */
  .pr-window {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(34, 197, 94, 0.16);
    box-shadow:
      0 8px 40px rgba(0, 0, 0, 0.35),
      0 0 60px rgba(34, 197, 94, 0.08);
  }

  .pr-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 14px;
    background: #0f172a;
  }

  .pr-dots {
    display: flex;
    gap: 5px;
  }

  .pr-dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: block;
  }

  .pr-dots span:nth-child(1) {
    background: #ef4444;
  }
  .pr-dots span:nth-child(2) {
    background: #eab308;
  }
  .pr-dots span:nth-child(3) {
    background: #22c55e;
  }

  .pr-title {
    color: #94a3b8;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    flex: 1;
  }

  .pr-live {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.6rem;
    font-weight: 600;
    color: #4ade80;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 3px 8px;
    border-radius: 999px;
    background: rgba(34, 197, 94, 0.12);
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .pr-live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.7);
    animation: pr-pulse 1.6s ease-out infinite;
  }

  @keyframes pr-pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.7);
    }
    70% {
      box-shadow: 0 0 0 8px rgba(74, 222, 128, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(74, 222, 128, 0);
    }
  }

  .pr-content {
    background: #1e293b;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* ── top row: radar + KPI ────────────────────────────────── */
  .pr-top {
    display: flex;
    gap: 14px;
    align-items: stretch;
  }

  @media (max-width: 639px) {
    .pr-top {
      flex-direction: column;
    }
  }

  .pr-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px 6px;
  }

  .pr-panel-title {
    color: #e2e8f0;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .pr-panel-meta {
    color: #64748b;
    font-size: 0.55rem;
    font-weight: 500;
    background: #0f172a;
    border-radius: 4px;
    padding: 2px 8px;
    border: 1px solid #1e293b;
  }

  /* ── radar ───────────────────────────────────────────────── */
  .pr-radar-panel {
    flex: 1.4;
    min-width: 0;
    background: #0f172a;
    border-radius: 10px;
    border: 1px solid #1e293b;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .pr-radar-wrap {
    flex: 1;
    padding: 4px 10px 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pr-radar-svg {
    width: 100%;
    height: auto;
    max-height: 230px;
    aspect-ratio: 1;
    display: block;
  }

  .pr-ring {
    fill: none;
    stroke: rgba(34, 197, 94, 0.22);
    stroke-width: 1;
  }

  .pr-ring-edge {
    stroke: rgba(34, 197, 94, 0.4);
    stroke-width: 1.25;
  }

  .pr-cross {
    stroke: rgba(34, 197, 94, 0.18);
    stroke-width: 1;
    stroke-dasharray: 2 4;
  }

  .pr-sweep {
    transform-origin: 100px 100px;
    animation: pr-sweep 4s linear infinite;
  }

  @keyframes pr-sweep {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .pr-blip {
    fill: #4ade80;
    filter: drop-shadow(0 0 4px rgba(74, 222, 128, 0.6));
    opacity: 0.55;
    animation: pr-blip-pulse 4s linear infinite;
  }

  @keyframes pr-blip-pulse {
    0%,
    100% {
      opacity: 0.45;
      r: 2.6;
    }
    50% {
      opacity: 1;
      r: 3.6;
    }
  }

  /* stagger blip pulses so each one lights up at a different moment of the sweep */
  .pr-blip-a {
    animation-delay: 0s;
  }
  .pr-blip-b {
    animation-delay: -0.8s;
  }
  .pr-blip-c {
    animation-delay: -1.6s;
  }
  .pr-blip-d {
    animation-delay: -2.4s;
  }
  .pr-blip-e {
    animation-delay: -3.2s;
  }
  .pr-blip-f {
    animation-delay: -2s;
  }

  .pr-center {
    fill: #4ade80;
    filter: drop-shadow(0 0 6px rgba(74, 222, 128, 0.8));
  }

  .pr-center-ring {
    fill: none;
    stroke: rgba(74, 222, 128, 0.55);
    stroke-width: 1;
  }

  /* ── KPI stack ───────────────────────────────────────────── */
  .pr-kpi-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 130px;
  }

  .pr-kpi-card {
    flex: 1;
    background: #0f172a;
    border: 1px solid #1e293b;
    border-radius: 10px;
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
  }

  .pr-kpi-label {
    color: #475569;
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pr-kpi-value {
    font-size: 1.6rem;
    font-weight: 800;
    line-height: 1;
  }

  .pr-kpi-sub {
    color: #94a3b8;
    font-size: 0.62rem;
    font-weight: 500;
  }

  .pr-kpi-sev {
    display: inline-block;
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 0.55rem;
    font-weight: 700;
  }

  .pr-sev-high {
    color: #fb923c;
    background: rgba(251, 146, 60, 0.12);
    border: 1px solid rgba(251, 146, 60, 0.25);
  }

  .pr-c-green {
    color: #4ade80;
  }

  .pr-c-amber {
    color: #fbbf24;
  }

  /* ── results list ───────────────────────────────────────── */
  .pr-results-panel {
    background: #0f172a;
    border: 1px solid #1e293b;
    border-radius: 10px;
    overflow: hidden;
  }

  .pr-results-list {
    list-style: none;
    margin: 0;
    padding: 4px 0 6px;
  }

  .pr-result-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 14px;
    border-bottom: 1px solid #1e293b;
  }

  .pr-result-row:last-child {
    border-bottom: none;
  }

  .pr-grade {
    width: 22px;
    height: 22px;
    border-radius: 5px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 800;
    color: #fff;
    flex-shrink: 0;
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.2);
  }

  /* Nutri-Score palette (matches the live radar dashboard) */
  .pr-grade-a {
    background: #038141;
  }
  .pr-grade-b {
    background: #85bb2f;
  }
  .pr-grade-c {
    background: #fecb02;
    color: #1f2937;
    text-shadow: none;
  }
  .pr-grade-d {
    background: #ee8100;
  }
  .pr-grade-e {
    background: #e63e11;
  }

  .pr-path {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }

  .pr-path-seg {
    display: inline-block;
    height: 7px;
    border-radius: 3px;
    background: #334155;
  }

  .pr-path-slash {
    color: #475569;
    font-size: 0.7rem;
    font-weight: 700;
  }

  .pr-bar-track {
    flex: 1;
    height: 6px;
    border-radius: 3px;
    background: #1e293b;
    overflow: hidden;
    min-width: 40px;
  }

  .pr-bar-fill {
    display: block;
    height: 100%;
    border-radius: 3px;
  }

  .pr-bar-a {
    background: #038141;
  }
  .pr-bar-b {
    background: #85bb2f;
  }
  .pr-bar-c {
    background: #fecb02;
  }
  .pr-bar-d {
    background: #ee8100;
  }
  .pr-bar-e {
    background: #e63e11;
  }

  .pr-score-num {
    font-size: 0.62rem;
    font-weight: 700;
    color: #cbd5e1;
    flex-shrink: 0;
    width: 30px;
    text-align: right;
  }

  /* hide a couple of rows on very narrow widths to keep the panel readable */
  @media (max-width: 480px) {
    .pr-result-row:nth-child(n + 4) {
      display: none;
    }
    .pr-path-seg:last-child {
      display: none;
    }
    .pr-path-slash {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pr-sweep,
    .pr-blip,
    .pr-live-dot {
      animation: none;
    }
    .pr-blip {
      opacity: 0.85;
    }
  }
</style>