---
/**
 * * Feature cards: three categories of what Plumber brings (aligned with CLI controls).
 */
import BeforeAfterPipeline from "@components/BeforeAfter/BeforeAfterPipeline.astro";
import FeatureCard from "@components/FeatureCard/FeatureCardLarge.astro";

interface FeatureData {
  icon: string;
  title: string;
  text: string;
}

const featureData: FeatureData[] = [
  {
    icon: "tabler/layout-grid",
    title: "Pipeline composition",
    text: "", // Rendered via description slot with inline code
  },
  {
    icon: "tabler/shield-check",
    title: "CI/CD container images",
    text: "Detects container images using mutable tags that can change unexpectedly. Ensures images come from trusted registries only.",
  },
  {
    icon: "tabler/lock",
    title: "Access and authorization",
    text: "Verifies that critical branches have proper protection settings.",
  },
];
---

<section id="plumber-features" class="mt-16 mb-12 md:mt-28 md:mb-24">
  <div class="site-container">
    <div class="mb-12 text-center">
      <p class="colored-title inline" data-mos="fade-up" data-mos-anchor="#plumber-features">
        How it works
      </p>
      <h2
        class="h2 mt-4"
        data-mos="fade-up"
        data-mos-delay="0.1"
        data-mos-anchor="#plumber-features"
      >
        Plumber scans your GitLab CI/CD configuration
      </h2>
      <p
        class="text-base-500 dark:text-base-400 description mx-auto mt-4 max-w-2xl"
        data-mos="fade-up"
        data-mos-delay="0.2"
        data-mos-anchor="#plumber-features"
      >
        Analyze your pipelines for security and compliance issues with automated checks.
      </p>
    </div>
    <div class="mb-8 md:mb-10">
      <BeforeAfterPipeline variant="cli" />
    </div>

    <div
      class="mb-8 flex flex-col items-center gap-3 md:mb-10"
      data-mos="fade-up"
      data-mos-delay="0.25"
      data-mos-anchor="#plumber-features"
    >
      <div
        class="h-px w-full max-w-xs bg-gradient-to-r from-transparent via-primary-500/40 to-transparent dark:via-primary-400/35"
        aria-hidden="true"
      />
      <p class="text-base-600 dark:text-base-400 max-w-xl px-4 text-center text-sm leading-relaxed">
        Each scan applies policy checks across your pipeline. Here is what Plumber controls.
      </p>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 md:grid-cols-4 md:gap-4">
      <FeatureCard
        title={featureData[0].title}
        icon={featureData[0].icon}
        compact
        data-mos="fade-up"
        data-mos-delay="0.3"
        data-mos-anchor="#plumber-features"
      >
        <span slot="description">
          Detects hardcoded jobs in the{" "}
          <code class="bg-base-300/80 dark:bg-base-600/80 rounded px-1.5 py-0.5 font-mono text-sm"
            >.gitlab-ci.yml</code
          >{" "}
          and verifies that all required template and component modules are included, up to date and do
          not follow unauthorized patterns (latest, main, etc.)
        </span>
      </FeatureCard>
      {
        featureData
          .slice(1)
          .map((feature, idx) => (
            <FeatureCard
              title={feature.title}
              text={feature.text}
              icon={feature.icon}
              compact
              data-mos="fade-up"
              data-mos-delay={`${(idx + 1) * 0.25 + 0.3}`}
              data-mos-anchor="#plumber-features"
            />
          ))
      }
      <FeatureCard
        title="See all controls"
        icon="tabler/list-check"
        compact
        highlight
        href="/docs/use-plumber/controls"
        data-mos="fade-up"
        data-mos-delay="1.05"
        data-mos-anchor="#plumber-features"
      >
        <span slot="description">
          Runners, caches, artifacts, and many other checks beyond these three. The documentation lists the
          full catalog and how each control maps to issue codes.
        </span>
      </FeatureCard>
    </div>
  </div>
</section>
