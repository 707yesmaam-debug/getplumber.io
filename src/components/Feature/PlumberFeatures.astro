---
/**
 * * Feature cards: three categories of what Plumber brings (aligned with CLI controls).
 */
import Button from "@components/Button/Button.astro";
import FeatureCard from "@components/FeatureCard/FeatureCardLarge.astro";

interface FeatureData {
  icon: string;
  title: string;
  text: string;
}

const featureData: FeatureData[] = [
  {
    icon: "tabler/layout-grid",
    title: "Pipeline composition",
    text: "", // Rendered via description slot with inline code
  },
  {
    icon: "tabler/shield-check",
    title: "CI/CD container images",
    text: "Detects container images using mutable tags that can change unexpectedly. Ensures images come from trusted registries only.",
  },
  {
    icon: "tabler/lock",
    title: "Access and authorization",
    text: "Verifies that critical branches have proper protection settings.",
  },
];
---

<section id="plumber-features" class="mb-12 md:mb-24 mt-16 md:mt-28">
  <div class="site-container">
    <div class="mb-12 text-center">
      <p class="colored-title inline" data-mos="fade-up" data-mos-anchor="#plumber-features">
        How it works
      </p>
      <h2
        class="h2 mt-4"
        data-mos="fade-up"
        data-mos-delay="0.1"
        data-mos-anchor="#plumber-features"
      >
        Plumber scans your GitLab CI/CD configuration
      </h2>
      <p
        class="description mx-auto mt-4 max-w-2xl"
        data-mos="fade-up"
        data-mos-delay="0.2"
        data-mos-anchor="#plumber-features"
      >
        Analyze your pipelines for security and compliance issues with automated checks.
      </p>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
      <FeatureCard
        title={featureData[0].title}
        icon={featureData[0].icon}
        data-mos="fade-up"
        data-mos-delay="0.3"
        data-mos-anchor="#plumber-features"
      >
        <span slot="description">
          Detects hardcoded jobs in the{" "}
          <code class="rounded bg-base-300/80 px-1.5 py-0.5 font-mono text-sm dark:bg-base-600/80">.gitlab-ci.yml</code>{" "}
          and verifies that all required template and component modules are included, up to date and do not follow unauthorized patterns (latest, main, etc.)
        </span>
      </FeatureCard>
      {
        featureData.slice(1).map((feature, idx) => (
          <FeatureCard
            title={feature.title}
            text={feature.text}
            icon={feature.icon}
            data-mos="fade-up"
            data-mos-delay={`${(idx + 1) * 0.25 + 0.3}`}
            data-mos-anchor="#plumber-features"
          />
        ))
      }
    </div>
    <div
      class="mt-12 flex justify-start"
      data-mos="fade-up"
      data-mos-delay="0.7"
      data-mos-anchor="#plumber-cta"
    >
      <Button variant="outline" href="/docs/use-plumber/controls" arrow="right"> And more</Button>
    </div>
  </div>
</section>
