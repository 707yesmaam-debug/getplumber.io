---
// Visual section divider with glow + centered accent.
// Intended for use between major homepage sections.
---

<div aria-hidden="true" class="relative -mb-8 md:-mb-16">
  <!-- soft glow -->
  <div
    class="bg-primary-500/40 dark:bg-primary-500/15 pointer-events-none absolute inset-x-0 top-0 mx-auto h-24 w-[min(900px,92%)] -translate-y-1/2 rounded-full blur-3xl"
  >
  </div>

  <div class="site-container">
    <div class="relative flex items-center justify-center">
      <!-- gradient rule -->
      <div
        class="via-primary-500/50 dark:via-primary-500/35 h-px w-full bg-gradient-to-r from-transparent to-transparent"
      >
      </div>

      <!-- center accent -->
      <div class="absolute grid place-items-center">
        <div
          class="bg-background ring-primary-500/25 dark:ring-primary-500/40 h-10 w-10 rounded-full shadow-sm ring-1"
        >
        </div>
        <div class="bg-primary-500/60 dark:bg-primary-500/60 absolute h-5 w-5 rounded-full"></div>
      </div>
    </div>
  </div>
</div>
