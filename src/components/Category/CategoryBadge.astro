---
import { getLocaleFromUrl } from "@js/localeUtils";
import { humanize } from "@js/textUtils";

interface Props {
  category: string | undefined;
  class?: string;
}

const { category, class: classList } = Astro.props as Props;

const currLocale = getLocaleFromUrl(Astro.url);
---

{
  category && (
    <span
      class:list={[
        "bg-base-200 dark:bg-base-900 rounded-full px-2 py-0.5 text-xs font-medium",
        classList,
      ]}
    >
      {humanize(category)}
    </span>
  )
}
