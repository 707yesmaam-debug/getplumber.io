<script>
  function initHiwAnimation() {
    document.querySelectorAll<HTMLElement>(".hiw-anim").forEach((el) => {
      if (el.hasAttribute("data-animated")) return;

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              el.setAttribute("data-animated", "");
              observer.unobserve(el);
            }
          }
        },
        { threshold: 0.25 },
      );

      observer.observe(el);
    });
  }

  initHiwAnimation();
  document.addEventListener("astro:after-swap", initHiwAnimation);
</script>
