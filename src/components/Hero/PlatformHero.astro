---
import Button from "@components/Button/Button.astro";
import HeroIllustration from "@images/hero-illustration.svg";
import { getLocaleFromUrl } from "@js/localeUtils";
import { Icon } from "astro-icon/components";

const currLocale = getLocaleFromUrl(Astro.url);
---

<section
  id="hero1"
  class="relative flex w-full flex-col gap-6 overflow-hidden pt-32 pb-16 md:pt-40 md:pb-16 lg:gap-10"
>
  <!-- background glow -->
  <div
    class="bg-primary-500/40 dark:bg-primary-500/50 absolute inset-0 bottom-1/2 -z-10 mx-auto aspect-square w-[65%] max-w-5xl -translate-y-2/3 rounded-full blur-[100px]"
    aria-hidden="true"
  >
  </div>

  <!-- background grid svg -->
  <div class="absolute inset-0 -z-20 flex overflow-hidden">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="text-base-500/5 dark:text-base-500/5 relative h-full w-full xl:scale-125"
      aria-hidden="true"
    >
      <defs>
        <pattern id="grid-pattern" width="60" height="60" patternUnits="userSpaceOnUse">
          <path d="M 60 0 L 0 0 0 60" fill="none" stroke="currentColor" stroke-width="2"></path>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid-pattern)"></rect>
    </svg>
  </div>

  <!-- hero items -->
  <div class="site-container mx-auto max-w-4xl gap-8 text-center">
    <!-- notification -->
    <!-- <div
      class="mb-4 flex w-full items-center justify-center"
      data-mos="fade-up"
      data-mos-anchor="#hero1"
    >
      <a
        href={"/blog/tsconfig-paths-setup"}
        class="border-primary-300 bg-base-100 text-base-800 ring-primary-500/20 hover:border-primary-400 dark:border-primary-300/20 dark:bg-base-800 dark:text-base-200 dark:hover:border-primary-400/60 flex items-center rounded-full border px-4 py-1 text-sm ring-2 transition"
      >
        <span class="flex items-center gap-2">
          <Icon
            name="tabler/wand"
            class="text-primary-600 dark:text-primary-300 inline h-4 w-4"
            aria-hidden="true"
          />New updates!</span
        ></a
      >
    </div> -->

    <!-- Hero text -->
    <h1
      class="from-base-900 to-base-600/90 dark:from-base-100 dark:to-base-400/90 bg-gradient-to-r bg-clip-text pb-4 text-5xl font-medium text-transparent md:text-6xl"
      data-mos="fade-up"
      data-mos-anchor="#hero1"
    >
      Reach CI/CD compliance <br />
      <span class="text-primary-500 text-shadow-base-700 text-shadow-xs">without effort</span>
    </h1>
    <p
      class="description mx-auto mt-2 max-w-sm sm:max-w-md md:max-w-lg"
      data-mos="fade-up"
      data-mos-delay="0.2"
      data-mos-anchor="#hero1"
    >
      Audit, detect, and remediate drifts — continuously. <br /> Be ready for regulatory demands (ISO
      27001, NIS2, DORA, SOC 2…).
    </p>
    <div
      class="mx-auto mt-6 flex max-w-md flex-col justify-center gap-4 px-4 sm:flex-row"
      data-mos="fade-up"
      data-mos-delay="0.3"
      data-mos-anchor="#hero1"
    >
      <Button variant="primary" href="/docs/getting-started">
        Get Started
      </Button>
      <a
        href="#howdygo-embed"
        class="button button--outline group sm:flex items-center gap-2 no-underline hidden"
      >
        <Icon
          name="tabler/chevron-down"
          class="text-primary-600 dark:text-primary-300 h-[1.4em] w-[1.4em] transition-transform group-hover:translate-y-0.5"
          aria-hidden="true"
        />
        Try interactive demo
      </a>
    </div>
  </div>
  <div class="px-2 sm:px-6" data-mos="fade-up" data-mos-delay="0.5" data-mos-anchor="#hero1">
    <div
      class="border-base-800 dark:border-base-800/60 shadow-base-900 dark:shadow-primary-500/20 plausible-event-name=Demo+Click mx-auto flex items-center justify-center overflow-hidden rounded-lg border-2 shadow-lg scroll-mt-24"
      id="howdygo-embed"
      style="width: 100%;
      max-width: 1388px;
"
    >
      <script src="https://js.howdygo.com/v1.2.1/index.js"></script>
      <div
        id="howdygo-wrapper"
        style="position: relative;
      width: 100%;
      height: 0;
      padding-bottom: calc(51.65227665706051%);
      overflow: hidden;"
      >
        <iframe
          id="howdygo-frame"
          src="https://app.howdygo.com/prescreen-embed/7229c52e-7c7d-40a9-9df8-98a6d1b72cde?mobileStrategy=inline&launchButton=Launch+interactive+demo"
          frameborder="0"
          scrolling="no"
          allow="autoplay"
          allowfullscreen
          title="interactive demo"
          style="position: absolute; top: -40px; left: 0; width: 100%; height: calc(100% + 40px)"
        ></iframe>
      </div>
    </div>
  </div>
</section>
