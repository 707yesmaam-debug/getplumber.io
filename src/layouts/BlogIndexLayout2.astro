---
import PostCard from "@components/PostCard/PostCardDetailed.astro";
import PostCardLarge from "@components/PostCard/PostCardLargeDetailed.astro";
import { type CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"blog">[];
  filterCategories?: string[];
  class?: string;
}

const { posts, filterCategories = [], class: className } = Astro.props as Props;
const hasFilters = filterCategories.length > 0;
---

{hasFilters && (
  <nav class="mt-8 mb-10 flex flex-wrap gap-2" id="blog-category-filters" aria-label="Filter blog posts by category">
    <a
      href="/blog"
      data-category="all"
      class="blog-filter-btn rounded-full border px-4 py-1.5 text-sm font-medium transition-colors"
    >
      All
    </a>
    {filterCategories.map((cat) => (
      <a
        href={`/blog?category=${encodeURIComponent(cat)}`}
        data-category={cat}
        class="blog-filter-btn rounded-full border px-4 py-1.5 text-sm font-medium transition-colors"
      >
        {cat}
      </a>
    ))}
  </nav>
)}

<div class:list={["grid gap-4 gap-y-12 md:grid-cols-2 lg:grid-cols-3", className]} id="blog-posts-grid">
  {
    posts.map((post, index) => {
      const cats = (post.data.categories ?? []).filter((c): c is string => typeof c === "string");
      const isFirst = index === 0;
      return (
        <div
          class:list={["blog-post-item", { "md:col-span-2 lg:col-span-3": isFirst }]}
          data-categories={JSON.stringify(cats)}
        >
          <div class:list={["blog-card-large", { hidden: !isFirst }]}>
            <PostCardLarge post={post} showDescription={true} />
          </div>
          <div class:list={["blog-card-small", { hidden: isFirst }]}>
            <PostCard post={post} showDescription={false} />
          </div>
        </div>
      );
    })
  }
</div>

<style is:global>
  .blog-filter-btn {
    color: var(--color-base-600);
    border-color: var(--color-base-300);
    background: transparent;
    cursor: pointer;
    text-decoration: none;
  }
  .blog-filter-btn:hover {
    color: var(--color-base-800);
    border-color: var(--color-base-400);
  }
  .blog-filter-btn.active {
    background: var(--color-primary-600);
    color: white;
    border-color: var(--color-primary-600);
  }
  .dark .blog-filter-btn {
    color: var(--color-base-400);
    border-color: var(--color-base-600);
  }
  .dark .blog-filter-btn:hover {
    color: var(--color-base-200);
    border-color: var(--color-base-400);
  }
  .dark .blog-filter-btn.active {
    background: var(--color-primary-400);
    color: var(--color-base-950);
    border-color: var(--color-primary-400);
  }
  .blog-post-item.hidden-by-filter {
    display: none;
  }
</style>

<script>
  function initBlogFilters() {
    const filterNav = document.getElementById('blog-category-filters');
    const posts = document.querySelectorAll<HTMLElement>('.blog-post-item');
    if (!filterNav || !posts.length) return;

    const buttons = filterNav.querySelectorAll<HTMLAnchorElement>('.blog-filter-btn');

    function applyFilter(category: string | null) {
      const activeCategory = category || 'all';

      buttons.forEach((btn) => {
        const isActive = btn.dataset.category === activeCategory;
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-pressed', String(isActive));
      });

      posts.forEach((post) => {
        const postCategories: string[] = JSON.parse(post.dataset.categories || '[]');
        const matches = activeCategory === 'all' || postCategories.includes(activeCategory);
        post.classList.toggle('hidden-by-filter', !matches);
      });

      let firstVisible = true;
      posts.forEach((post) => {
        if (post.classList.contains('hidden-by-filter')) return;

        const large = post.querySelector<HTMLElement>('.blog-card-large');
        const small = post.querySelector<HTMLElement>('.blog-card-small');

        if (firstVisible) {
          post.classList.add('md:col-span-2', 'lg:col-span-3');
          if (large) large.classList.remove('hidden');
          if (small) small.classList.add('hidden');
          firstVisible = false;
        } else {
          post.classList.remove('md:col-span-2', 'lg:col-span-3');
          if (large) large.classList.add('hidden');
          if (small) small.classList.remove('hidden');
        }
      });
    }

    function getCategoryFromUrl() {
      const params = new URLSearchParams(window.location.search);
      return params.get('category');
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const category = btn.dataset.category!;
        const url = category === 'all'
          ? window.location.pathname
          : `${window.location.pathname}?category=${encodeURIComponent(category)}`;
        window.history.pushState({}, '', url);
        applyFilter(category === 'all' ? null : category);
      });
    });

    window.addEventListener('popstate', () => {
      applyFilter(getCategoryFromUrl());
    });

    applyFilter(getCategoryFromUrl());
  }

  initBlogFilters();
  document.addEventListener('astro:after-swap', initBlogFilters);
</script>
