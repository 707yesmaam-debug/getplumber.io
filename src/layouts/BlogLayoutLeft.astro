---
import Button from "@components/Button/Button.astro";
import PostCard from "@components/PostCard/PostCard.astro";
import TableOfContents from "@components/TableOfContents/TableOfContents.astro";
import { getAllPosts } from "@js/blogUtils";
import { getLocaleFromUrl } from "@js/localeUtils";
import { formatDate, humanize, slugify } from "@js/textUtils";
import { Image } from "astro:assets";
import { type CollectionEntry, getEntries } from "astro:content";

// main layout
import BaseLayout from "./BaseLayout.astro";

interface Props {
  post: CollectionEntry<"blog">;
  headings: import("astro").MarkdownHeading[];
}

const { post, headings } = Astro.props as Props;
const { title, description, authors, pubDate, updatedDate, heroImage } = post.data;

const currLocale = getLocaleFromUrl(Astro.url);
const authorsData = await getEntries(authors);

// Related posts: most shared categories first, newest first as tiebreaker
// (internal circulation between posts helps both readers and SEO)
const postCategories = post.data.categories?.filter(Boolean) ?? [];
const allPosts = await getAllPosts(currLocale, true);
const relatedPosts = allPosts
  .filter((other) => other.id !== post.id)
  .map((other) => ({
    post: other,
    shared: (other.data.categories?.filter(Boolean) ?? []).filter((category) =>
      postCategories.includes(category),
    ).length,
  }))
  .filter(({ shared }) => shared > 0)
  .sort(
    (a, b) =>
      b.shared - a.shared || b.post.data.pubDate.getTime() - a.post.data.pubDate.getTime(),
  )
  .slice(0, 3)
  .map(({ post: related }) => related);
---

<BaseLayout
  type="blog"
  title={title}
  description={description}
  heroImage={heroImage}
  authorsData={authorsData}
  postFrontmatter={post.data}
>
  <article class="site-container mt-16 md:mt-28" data-pagefind-ignore>
    <div class="mx-auto mt-10 grid w-full max-w-2xl gap-10 lg:max-w-none lg:grid-cols-3">
      <!-- table of contents + hero on desktop -->
      <aside class="lg:order-2" data-pagefind-ignore>
        <!-- hero at top of sidebar on desktop (not sticky, scrolls with page) -->
        {
          heroImage && (
            <div class="hidden lg:block lg:mb-6">
              <Image
                src={heroImage}
                alt={`Cover for ${title}`}
                width={400}
                quality="high"
                class="border-base-300 dark:border-base-600/60 w-full rounded-lg border object-cover"
                loading="eager"
                format="webp"
              />
            </div>
          )
        }
        <div class="lg:sticky lg:top-20 lg:h-[calc(100vh-5rem)]">
          <TableOfContents headings={headings} headingIcons={post.data.tocHeadingIcons} />
        </div>
      </aside>

      <!-- main content -->
      <div class="lg:col-span-2">
        <div class="text-base-content text-base">
          <!-- hero at top of page on mobile/tablet -->
          {
            heroImage && (
              <div class="mb-10 lg:hidden">
                <Image
                  src={heroImage}
                  alt={`Cover for ${title}`}
                  width={800}
                  quality="high"
                  class="border-base-300 dark:border-base-600/60 w-full rounded-lg border object-cover"
                  loading="eager"
                  format="webp"
                />
              </div>
            )
          }
          {
            updatedDate && (
              <div class="mb-6 italic">
                <time datetime={updatedDate.toISOString()}>
                  Updated: {formatDate(updatedDate, currLocale)}
                </time>
              </div>
            )
          }
          <!-- Title rendered here (not in post markdown) so every post has exactly one H1 -->
          <h1 class="text-foreground mb-4 text-3xl font-semibold md:text-4xl">{title}</h1>
          <section id="blog-post-content" class="markdown-content mx-auto max-w-2xl lg:max-w-none">
            <slot />
          </section>

          <!-- related posts -->
          {
            relatedPosts.length > 0 && (
              <div class="mt-16">
                <h2 class="text-2xl font-semibold md:text-3xl">Related posts</h2>
                <div class="mt-6 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
                  {relatedPosts.map((relatedPost) => (
                    <PostCard post={relatedPost} />
                  ))}
                </div>
              </div>
            )
          }

          <!-- button to go back to all posts -->
          <div class="mt-16 flex">
            <Button variant="outline" href={"/blog"} arrow="left" class="py-2">
              Back to all posts
            </Button>
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
