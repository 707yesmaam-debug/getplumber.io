---
/**
 * Renders the full list of Plumber issues grouped by category,
 * with a GitLab/GitHub tab toggle at the top. Both lists are rendered
 * server-side; the inactive one is hidden via class. The active tab is
 * persisted to localStorage under "plumber:docs:provider" and synced
 * to the URL as `?p=gitlab|github` so links into the issue detail page
 * preserve the choice.
 *
 * Used in the Issues index page (use-plumber/issues.mdx).
 */
import { Icon } from "astro-icon/components";

import ProviderTabs from "@/docs/components/mdx-components/ProviderTabs.astro";
import { categoryOrderRank, issueCodeRank } from "@/data/issueCategoryOrder";
import {
  type IssueProviderContent,
  issueDisplayTitle,
  issues,
  isVisibleProviderContent,
  type Provider,
  SHOW_ROADMAP,
} from "@/data/issues";
import ProductScopeBadge from "@/docs/components/mdx-components/ProductScopeBadge.astro";
import Aside from "@/docs/components/mdx-components/Aside.astro";
import { isCliDocsPath } from "@/docs/js/docsUtils";

interface Props {
  /** When false, render only issue panels (tabs live elsewhere on the page). */
  showProviderTabs?: boolean;
}

const { showProviderTabs = true } = Astro.props;

const docsBase = isCliDocsPath(Astro.url.pathname) ? "/docs/cli" : "/docs/use-plumber";

export const severityBadge: Record<string, string> = {
  critical:
    "bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-400 ring-red-300 dark:ring-red-700/50",
  high: "bg-orange-100 dark:bg-orange-900/40 text-orange-700 dark:text-orange-400 ring-orange-300 dark:ring-orange-700/50",
  medium:
    "bg-yellow-100 dark:bg-yellow-900/40 text-yellow-700 dark:text-yellow-400 ring-yellow-300 dark:ring-yellow-700/50",
  low: "bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400 ring-blue-300 dark:ring-blue-700/50",
};

export const fixDurationBadge: Record<string, string> = {
  "very quick":
    "bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300 ring-emerald-300/70 dark:ring-emerald-700/60",
  immediate:
    "bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300 ring-emerald-300/70 dark:ring-emerald-700/60",
  quick:
    "bg-primary/10 text-primary dark:text-primary ring-primary/40",
  medium:
    "bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300 ring-yellow-300/70 dark:ring-yellow-700/60",
  long:
    "bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300 ring-orange-300/70 dark:ring-orange-700/60",
  extended:
    "bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300 ring-red-300/70 dark:ring-red-700/60",
};

type Row = { code: string; content: IssueProviderContent; title: string };

function sortCategoryEntries(entries: [string, Row[]][]): [string, Row[]][] {
  return [...entries].sort(([a], [b]) => {
    const diff = categoryOrderRank(a) - categoryOrderRank(b);
    return diff !== 0 ? diff : a.localeCompare(b);
  });
}

function groupByCategory(rows: Row[]): Map<string, Row[]> {
  const grouped = new Map<string, Row[]>();
  for (const row of rows) {
    const cat = row.content.category;
    if (!grouped.has(cat)) grouped.set(cat, []);
    grouped.get(cat)!.push(row);
  }
  for (const list of grouped.values()) {
    list.sort((a, b) => issueCodeRank(a.code) - issueCodeRank(b.code));
  }
  return grouped;
}

const providers: { id: Provider; label: string; icon: string }[] = [
  { id: "gitlab", label: "GitLab", icon: "tabler/brand-gitlab" },
  { id: "github", label: "GitHub", icon: "tabler/brand-github" },
];

// Within a provider, rows are split into a shipping group (status !== "roadmap")
// and a roadmap group. Each group is then category-grouped. We do this on the
// component side rather than mixing both into one list per category — interlacing
// shipping/roadmap rows inside a single category section made the active controls
// hard to spot under the noise of the much-longer roadmap list.
type ProviderGroups = { shipping: Map<string, Row[]>; roadmap: Map<string, Row[]> };

function splitByStatus(rows: Row[]): ProviderGroups {
  const shipping: Row[] = [];
  const roadmap: Row[] = [];
  for (const row of rows) {
    if (SHOW_ROADMAP && row.content.status === "roadmap") {
      roadmap.push(row);
    } else if (row.content.status !== "roadmap") {
      shipping.push(row);
    }
  }
  return { shipping: groupByCategory(shipping), roadmap: groupByCategory(roadmap) };
}

const groupedByProvider: Record<Provider, ProviderGroups> = {
  gitlab: splitByStatus(
    Object.entries(issues)
      .filter(([, doc]) => doc.gitlab != null && isVisibleProviderContent(doc.gitlab))
      .map(([code, doc]) => ({
        code,
        content: doc.gitlab!,
        title: issueDisplayTitle(doc, "gitlab")!,
      })),
  ),
  github: splitByStatus(
    Object.entries(issues)
      .filter(([, doc]) => doc.github != null && isVisibleProviderContent(doc.github))
      .map(([code, doc]) => ({
        code,
        content: doc.github!,
        title: issueDisplayTitle(doc, "github")!,
      })),
  ),
};

// Default provider for SSR (the inline script swaps based on URL/storage).
const defaultProvider: Provider = "gitlab";
---

{showProviderTabs && <ProviderTabs defaultProvider={defaultProvider} />}

{
  providers.map((p) => {
    const groups = groupedByProvider[p.id];
    const hasShipping = groups.shipping.size > 0;
    const hasRoadmap = groups.roadmap.size > 0;
    const hasContent = hasShipping || hasRoadmap;
    return (
      <div
        data-provider-panel={p.id}
        class:list={["provider-panel not-prose mt-6", p.id === defaultProvider ? "" : "hidden"]}
      >
        {p.id === "github" && (
          <Aside variant="info" title="Open Source CLI only">
            <p>
              GitHub Actions issues are reported by the Open Source CLI only. Plumber Platform
              does not scan GitHub Actions workflows yet.
            </p>
          </Aside>
        )}

        {!hasContent && (
          <p class="text-sm text-muted-foreground">
            No {p.label} issues yet.
          </p>
        )}

        {SHOW_ROADMAP && hasShipping && hasRoadmap && p.id === "gitlab" && (
          <div class="mb-6 flex items-center gap-2 text-base font-semibold text-foreground">
            <span class="text-amber-600 dark:text-amber-400">★</span>
            <span>Currently shipping</span>
            <span class="text-xs font-normal text-muted-foreground">
              {Array.from(groups.shipping.values()).reduce((n, l) => n + l.length, 0)} issues
            </span>
          </div>
        )}

        {(() => {
          const renderCategory = (category: string, entries: Row[]) => (
            <div>
              <h2 class="text-sm font-semibold uppercase tracking-widest text-muted-foreground mb-3 pb-2 border-b border-border">
                {category}
              </h2>
              <div class="flex flex-col">
                {entries.map((entry) => (
                  <a
                    href={`${docsBase}/issues/${entry.code}?p=${p.id}`}
                    class="group flex items-center gap-3 rounded-md border border-border bg-muted/30 px-3 py-2 hover:border-muted-foreground/40 hover:bg-muted/70 transition-all"
                  >
                    <span
                      class="shrink-0 font-mono text-xs font-bold text-emerald-600 dark:text-emerald-400 w-[5rem]"
                      title="Unique identifier for this issue"
                    >
                      {entry.code}
                    </span>
                    <span class="flex-1 min-w-0">
                      <span class="block text-xs md:text-sm text-foreground/80 group-hover:text-foreground transition-colors leading-snug">
                        {entry.title}
                      </span>
                    </span>
                    <div class="flex items-center gap-1.5 shrink-0">
                      <ProductScopeBadge
                        scope={
                          entry.content.productScope === "cli"
                            ? "cli"
                            : entry.content.productScope === "platform"
                              ? "platform"
                              : "all"
                        }
                      />
                      {SHOW_ROADMAP && entry.content.status === "roadmap" && (
                        <span
                          class="inline-flex items-center leading-none gap-1 rounded px-2 text-[10px] h-[26px] md:text-xs font-medium ring-1 ring-inset bg-amber-100 dark:bg-amber-900/40 text-amber-800 dark:text-amber-200 ring-amber-300 dark:ring-amber-700/50"
                          title="On the roadmap — Rego exists but findings are held back by the engine's bench gate."
                        >
                          ⏳ Roadmap
                        </span>
                      )}
                      <span
                        class={`inline-flex items-center leading-none gap-1 rounded px-2 text-[10px] h-[26px] md:text-xs font-medium ring-1 ring-inset ${severityBadge[entry.content.severity]}`}
                        title="How severe the impact is if this issue is not fixed"
                      >
                        <Icon name="tabler/alert-triangle" color="currentColor" size="15px" />
                        {entry.content.severity.charAt(0).toUpperCase() + entry.content.severity.slice(1)}
                      </span>
                      <span
                        class={`inline-flex items-center leading-none gap-1 rounded px-2 text-[10px] h-[26px] md:text-xs font-medium ring-1 ring-inset ${
                          fixDurationBadge[entry.content.fixDuration] ?? "bg-muted text-muted-foreground ring-border"
                        }`}
                        title="Approximate time needed to fix this issue"
                      >
                        <Icon name="tabler/clock" color="currentColor" size="15px" />
                        {(entry.content.fixDuration.charAt(0).toUpperCase() + entry.content.fixDuration.slice(1)).replace("quick", "Quick")}
                      </span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          );
          const roadmapCount = Array.from(groups.roadmap.values()).reduce((n, l) => n + l.length, 0);
          return (
            <>
              <div class="space-y-10">
                {sortCategoryEntries([...groups.shipping.entries()]).map(([cat, entries]) =>
                  renderCategory(cat, entries),
                )}
              </div>

              {SHOW_ROADMAP && hasRoadmap && (
                <>
                  <div class="mt-12 mb-6 border-t border-border pt-6 flex flex-wrap items-center gap-3">
                    <span class="text-base font-semibold text-foreground">
                      <span class="text-amber-600 dark:text-amber-400">⏳</span> On the roadmap
                    </span>
                    <span class="text-xs text-muted-foreground">
                      {roadmapCount} issues
                    </span>
                  </div>
                  <p class="text-xs text-muted-foreground mb-6 max-w-3xl leading-relaxed">
                    The controls below are implemented in the engine's Rego
                    catalog but their findings are held back by the engine's
                    dev-side bench gate before reaching any output. They are
                    listed so the codes Plumber may surface in future releases
                    stay stable. Adding them to your{" "}
                    <code class="bg-muted px-1.5 py-0.5 rounded text-foreground">.plumber.yaml</code> today has no effect.
                  </p>
                  <div class="space-y-10">
                    {sortCategoryEntries([...groups.roadmap.entries()]).map(([cat, entries]) =>
                      renderCategory(cat, entries),
                    )}
                  </div>
                </>
              )}
            </>
          );
        })()}
      </div>
    );
  })
}
