---
import {
  Breadcrumb,
  BreadcrumbItem,
  BreadcrumbLink,
  BreadcrumbList,
  BreadcrumbPage,
  BreadcrumbSeparator,
} from "@/components/starwind/breadcrumb";
import { isCliDocsPath } from "@/docs/js/docsUtils";

const docsBase = isCliDocsPath(Astro.url.pathname) ? "/docs/cli" : "/docs/use-plumber";
---

<div class="not-content">
  <Breadcrumb class="mb-4 text-xs md:text-sm">
    <BreadcrumbList class="list-none gap-0!">
      <BreadcrumbItem class="pl-0! pr-3">
        <BreadcrumbLink
          href={`${docsBase}/controls`}
          class="text-[var(--docs-link)] font-semibold hover:text-[var(--docs-link-hover)]!"
        >
          Controls
        </BreadcrumbLink>
      </BreadcrumbItem>
      <BreadcrumbSeparator />
      <BreadcrumbItem class="pl-3">
        <BreadcrumbPage class="rounded-md bg-muted px-2 py-0.5 text-foreground">
          Issues
        </BreadcrumbPage>
      </BreadcrumbItem>
    </BreadcrumbList>
  </Breadcrumb>
</div>
