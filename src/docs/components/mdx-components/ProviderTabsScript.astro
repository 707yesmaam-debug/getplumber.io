---
/**
 * Provider-tab toggle script shared between the controls and issues
 * documentation pages. Renders a single inline `<script>` that:
 *   - reads `?p=gitlab|github` from the URL, then localStorage, then
 *     falls back to "gitlab";
 *   - shows/hides `[data-provider-panel]` blocks accordingly;
 *   - rewrites issue-link query strings so cross-page navigation
 *     preserves the active provider.
 *
 * Wrapped in an `.astro` file so MDX pages can use it without running
 * into the MDX parser's interpretation of `{` characters inside a
 * script tag.
 */
---
<script is:inline>
  (function () {
    const STORAGE_KEY = "plumber:docs:provider";

    function panelExists(p) {
      return !!document.querySelector('[data-provider-panel="' + p + '"]');
    }

    function rewriteIssueLinks(p) {
      document.querySelectorAll('a[href*="/issues/ISSUE-"]').forEach(function (a) {
        const href = a.getAttribute("href") || "";
        const m = href.match(/^(\/(?:docs\/(?:use-plumber|cli))\/issues\/ISSUE-\d+)(\?.*)?$/);
        if (m) {
          a.setAttribute("href", m[1] + "?p=" + p);
        }
      });
    }

    /** Keep the right sidebar TOC in sync with the active provider panel. */
    function syncTableOfContents(provider) {
      const content = document.querySelector(".docs-markdown-content");
      const toc = document.getElementById("docs-page-toc");
      if (!content || !toc) return;

      const visibleIds = new Set();

      content.querySelectorAll(":scope > h2, :scope > h3, :scope > h4").forEach(function (h) {
        if (h.id) visibleIds.add(h.id);
      });

      const panel = document.querySelector('[data-provider-panel="' + provider + '"]');
      if (panel) {
        panel.querySelectorAll("h1, h2, h3, h4").forEach(function (h) {
          if (!h.id) return;
          if (h.closest("[data-exclude-from-toc]")) return;
          visibleIds.add(h.id);
        });
      }

      toc.querySelectorAll(".toc-link").forEach(function (link) {
        const href = link.getAttribute("href") || "";
        const id = href.charAt(0) === "#" ? href.slice(1) : href;
        const show = visibleIds.has(id);
        link.style.display = show ? "" : "none";
        link.setAttribute("aria-hidden", show ? "false" : "true");
      });
    }

    function scheduleTableOfContentsSync(provider) {
      function run() {
        syncTableOfContents(provider);
      }
      if (document.getElementById("docs-page-toc")) {
        requestAnimationFrame(run);
      } else if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", run, { once: true });
      } else {
        requestAnimationFrame(run);
      }
    }

    function setProvider(p) {
      if (!panelExists(p)) return;
      document.querySelectorAll("[data-provider-panel]").forEach(function (panel) {
        const active = panel.getAttribute("data-provider-panel") === p;
        panel.classList.toggle("hidden", !active);
      });
      document.querySelectorAll("[data-provider-tab]").forEach(function (tab) {
        const active = tab.getAttribute("data-provider-tab") === p;
        tab.setAttribute("aria-selected", active ? "true" : "false");
      });
      rewriteIssueLinks(p);
      scheduleTableOfContentsSync(p);
      try {
        localStorage.setItem(STORAGE_KEY, p);
      } catch (e) {
        /* localStorage unavailable (private mode, etc.); silently ignore. */
      }
      const url = new URL(window.location.href);
      url.searchParams.set("p", p);
      window.history.replaceState({}, "", url.toString());
    }

    function initialProvider() {
      const params = new URLSearchParams(window.location.search);
      const fromUrl = params.get("p");
      if ((fromUrl === "gitlab" || fromUrl === "github") && panelExists(fromUrl)) {
        return fromUrl;
      }
      let fromStorage = null;
      try {
        fromStorage = localStorage.getItem(STORAGE_KEY);
      } catch (e) {
        /* localStorage unavailable (private mode, etc.); silently ignore. */
      }
      if ((fromStorage === "gitlab" || fromStorage === "github") && panelExists(fromStorage)) {
        return fromStorage;
      }
      return "gitlab";
    }

    setProvider(initialProvider());

    document.addEventListener("astro:page-load", function () {
      setProvider(initialProvider());
    });

    document.querySelectorAll("[data-provider-tab]").forEach(function (tab) {
      tab.addEventListener("click", function () {
        const p = tab.getAttribute("data-provider-tab");
        if (p === "gitlab" || p === "github") setProvider(p);
      });
    });
  })();
</script>
