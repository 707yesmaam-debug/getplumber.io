---
interface Props {
  href: string;
  newTab?: boolean; // defaults to false
  rest?: Partial<HTMLAnchorElement>; // catch-all for any additional parameters, such as "aria-label"
}

const { href, newTab = false, ...rest } = Astro.props as Props;

// Normalize internal links to remove trailing slash (except root)
const domain = import.meta.env.SITE;
const isExternal = !href.includes(domain) && !href.startsWith("/") && !href.startsWith("#");
const normalizedHref =
  isExternal || href === "/" || !href.startsWith("/") || !href.endsWith("/")
    ? href
    : href.slice(0, -1);
---

<a
  href={normalizedHref}
  class="docs-primary-focus docs-nav__link--sidebar mr-auto"
  target={newTab ? "_blank" : undefined}
  rel={newTab ? "noopener noreferrer" : undefined}
  {...rest}
>
  <slot />
</a>
