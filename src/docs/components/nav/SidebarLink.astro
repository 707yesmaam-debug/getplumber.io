---
import type { ComponentProps } from "astro/types";

import Badge from "@/docs/components/mdx-components/Badge.astro";
import { getLocaleFromUrl } from "@/docs/js/localeUtils";
import { getLocalizedRoute } from "@/docs/js/translationUtils";

/**
 * Compares two paths ensuring they both have trailing slashes for consistency
 * @param path1 First path to compare
 * @param path2 Second path to compare
 * @returns boolean indicating if the paths are equal
 */
const comparePathsWithTrailingSlash = (path1: string, path2: string): boolean => {
  const ensureTrailingSlash = (path: string): string => (path.endsWith("/") ? path : `${path}/`);

  return ensureTrailingSlash(path1) === ensureTrailingSlash(path2);
};

interface Props {
  link: string;
  text: string;
  indent?: boolean;
  badge?: ComponentProps<typeof Badge>;
  /** When true, also active for paths under this link (e.g. issue detail pages under the Issues index). */
  highlightDescendants?: boolean;
}

const { link, text, indent = false, badge, highlightDescendants = false } = Astro.props;

// get the current page locale to use in links to other pages
const currLocale = getLocaleFromUrl(Astro.url);

// internal link - normalize to remove trailing slash (except root)
let actualLink = link === "/" ? "/" : link.replace(/\/$/, "");

const pathname = Astro.url.pathname;
const linkWithSlash = actualLink.endsWith("/") ? actualLink : `${actualLink}/`;
const currentWithSlash = pathname.endsWith("/") ? pathname : `${pathname}/`;

const currentPath =
  highlightDescendants && actualLink !== "/"
    ? comparePathsWithTrailingSlash(pathname, actualLink) ||
      currentWithSlash.startsWith(linkWithSlash)
    : comparePathsWithTrailingSlash(pathname, actualLink);
---

<li
  class:list={[
    indent &&
      "border-primary-500/45 ml-0.5 border-l-2 border-solid pl-3 dark:border-primary-400/50",
  ]}
>
  <a
    href={actualLink}
    class:list={[
      "docs-nav__link--sidebar docs-primary-focus block text-base md:text-sm",
      {
        // styling for current active page link
        "text-foreground font-medium": currentPath,
      },
    ]}
  >
    <div class="flex items-center gap-2">
      {
        indent && (
          <span
            class="text-primary-600 dark:text-primary-400 shrink-0 text-sm leading-none font-medium tabular-nums"
            aria-hidden="true"
          >
            ↳
          </span>
        )
      }
      <span>{text}</span>
      {badge && <Badge text={badge.text} variant={badge.variant} />}
    </div>
  </a>
</li>
